# Ollama — Perfil ALTO (16+ GB RAM, GPU o Apple Silicon M-series)
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.5
LLM_NUM_CTX=8192

# Redis
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=minuta:
REDIS_TTL_SECONDS=86400

# RAG / Chroma
CHROMA_DIR=/app/data/chroma_db
CHROMA_COLLECTION=normativa_junji
DOCUMENTS_DIR=/app/documentos_normativos
RETRIEVER_K=4
RETRIEVER_FETCH_K=20

# API
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
