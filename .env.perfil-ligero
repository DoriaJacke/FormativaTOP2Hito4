# Ollama — Perfil LIGERO (8 GB RAM, sin GPU dedicada)
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2:1b
EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.1
LLM_NUM_CTX=2048

# Redis
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=minuta:
REDIS_TTL_SECONDS=86400

# RAG / Chroma — menos fragmentos = menos tokens en el prompt
CHROMA_DIR=/app/data/chroma_db
CHROMA_COLLECTION=normativa_junji
DOCUMENTS_DIR=/app/documentos_normativos
RETRIEVER_K=2
RETRIEVER_FETCH_K=8

# API
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
